# Copy this file to .env for local development. Keep real secrets in local
# ignored files only.

APP_ENV=dev
DATABASE_URL=postgresql+psycopg://rag_exam:rag_exam@localhost:5434/rag_exam

# Local object storage for converted media.
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_LOCAL_ROOT=./local/object-store
OBJECT_STORAGE_DEV_PRESIGN_BASE_URL=http://localhost:8000/_dev/object
OBJECT_STORAGE_DEV_PRESIGN_SECRET=dev-secret
ENABLE_DEV_ROUTES=true

# Local Redis/Valkey-backed cost rate limiting.
RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_KEY_SECRET=dev-rate-limit-secret
RATE_LIMIT_SEARCH_USER=60/minute
RATE_LIMIT_SEARCH_ANON=20/minute
RATE_LIMIT_STUDY_USER=10/hour
RATE_LIMIT_STUDY_ANON=3/hour

# Local auth fallback. Production uses Clerk through Fly secrets.
ACCESS_AUTH_PROVIDER=stub_header
ACCESS_AUTH_HEADER_NAME=x-user-email
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Retrieval defaults. Set VOYAGE_API_KEY only in local ignored env files.
RETRIEVAL_BACKEND=postgres
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_ID=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768
RERANK_ENABLED=false
VOYAGE_API_KEY=

# Clerk placeholders for production-like local testing only.
CLERK_SECRET_KEY=
CLERK_AUTHORIZED_PARTIES=
